# ══════════════════════════════════════════════════════════════════
# HDTS Monitoring — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── MySQL ─────────────────────────────────────────────────────────
# Root password (only needed for initial setup and admin tasks)
MYSQL_ROOT_PASSWORD=change_me_root_password

# App user (used by the PHP application)
MYSQL_USER=hdts_user
MYSQL_PASSWORD=change_me_app_password

# Port to expose MySQL on localhost (for local admin tools, optional)
DB_EXTERNAL_PORT=33060

# ── App ───────────────────────────────────────────────────────────
# Port the web app listens on (behind your reverse proxy)
APP_PORT=8080

# ── Tailscale (optional) ──────────────────────────────────────────
# Needed only if you use the /tailscale route in the app
TAILSCALE_TAILNET=
TAILSCALE_TOKEN=

# ── SMTP (PHPMailer — login verification emails) ──────────────────
# The app sends login verification codes by email.
# Configure your own SMTP account here.
SMTP_HOST=smtp.purelymail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@beesport.online

# ── DeepL Translation (optional) ─────────────────────────────────
# If blank, the translation feature will fail silently.
# Get a free API key at: https://www.deepl.com/pro-api
DEEPL_API_KEY=

# ── Camera NVR TCP Proxy configuration (Option A) ─────────────────
# Used to securely route stream start commands and connectivity tests
# to Tailscale cameras via a dedicated proxy server.
PROXY_HOST=213.160.161.250
PROXY_PORT=8080
PROXY_KEY=palo999
